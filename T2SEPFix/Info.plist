<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- ================================================================
	     T2SEPFix.kext
	     Fixes T2 chip communication on MacBookAir8,1 / MacBookAir8,2
	     running macOS Sequoia via OpenCore Legacy Patcher.

	     Two IOKit personalities:
	       T2SEPFix-System   — removes sep-booted NVRAM variable early
	       T2SEPFix-T2Device — ensures T2 PCIe device is in D0 with MSI
	     ================================================================ -->

	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>

	<key>CFBundleExecutable</key>
	<string>T2SEPFix</string>

	<key>CFBundleIdentifier</key>
	<string>com.oclp.kext.T2SEPFix</string>

	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>

	<key>CFBundleName</key>
	<string>T2SEPFix</string>

	<key>CFBundlePackageType</key>
	<string>KEXT</string>

	<key>CFBundleShortVersionString</key>
	<string>1.0.0</string>

	<key>CFBundleVersion</key>
	<string>1.0.0</string>

	<key>NSHumanReadableCopyright</key>
	<string>Copyright © 2024 OpenCore Legacy Patcher contributors. All rights reserved.</string>

	<!-- ================================================================
	     IOKitPersonalities
	     ================================================================ -->
	<key>IOKitPersonalities</key>
	<dict>

		<!-- ============================================================
		     Personality 1: T2SEPFix-System
		     Matched against IOResources via IOResourceMatch = "IOKit".
		     IOResources is published very early in boot, before
		     AppleKeyStore reads NVRAM, giving us the window we need
		     to delete the sep-booted variable.

		     IOProbeScore 9000 ensures we beat other drivers that also
		     match IOResources and might indirectly trigger SEP init.
		     ============================================================ -->
		<key>T2SEPFix-System</key>
		<dict>
			<key>CFBundleIdentifier</key>
			<string>com.oclp.kext.T2SEPFix</string>

			<key>IOClass</key>
			<string>T2SEPFix</string>

			<key>IOMatchCategory</key>
			<string>T2SEPFix-System</string>

			<key>IOProviderClass</key>
			<string>IOResources</string>

			<!-- Match as soon as the IOKit runtime is up. -->
			<key>IOResourceMatch</key>
			<string>IOKit</string>

			<!-- High probe score to run before other IOResources consumers. -->
			<key>IOProbeScore</key>
			<integer>9000</integer>
		</dict>

		<!-- ============================================================
		     Personality 2: T2SEPFix-T2Device
		     Matched against the T2 Security Enclave Processor PCIe
		     endpoint: Apple vendor 0x106b, device ID 0x1801.

		     IOPCIMatch format: <DeviceID><VendorID>  (little-endian word
		     concatenation as displayed by lspci / IOPCIFamily).

		     This personality:
		       — Ensures Memory Space + Bus Master bits are set (D0)
		       — Enables MSI with up to 8 vectors if not already enabled
		       — Probes BAR4 mailbox reply counter for diagnostics

		     IOProbeScore 9000 ensures we probe before any Apple kext
		     that might claim the same device.
		     ============================================================ -->
		<key>T2SEPFix-T2Device</key>
		<dict>
			<key>CFBundleIdentifier</key>
			<string>com.oclp.kext.T2SEPFix</string>

			<key>IOClass</key>
			<string>T2PCIeFix</string>

			<key>IOMatchCategory</key>
			<string>T2SEPFix-T2Device</string>

			<key>IOProviderClass</key>
			<string>IOPCIDevice</string>

			<!-- Match Apple T2 PCIe endpoint: vendor=0x106b device=0x1801 -->
			<key>IOPCIMatch</key>
			<string>0x1801106b</string>

			<!-- Probe before Apple's own T2/SEP manager kexts. -->
			<key>IOProbeScore</key>
			<integer>9000</integer>
		</dict>

	</dict>

	<!-- ================================================================
	     OSBundleLibraries
	     Minimum versions that cover all APIs used in this kext:
	       IOPCIFamily   — IOPCIDevice, BAR mapping, configRead/Write
	       kpi.iokit     — IOService, IOMemoryMap, waitForMatchingService
	       kpi.libkern   — OSObject, OSDictionary, OSString, IOLog
	     ================================================================ -->
	<key>OSBundleLibraries</key>
	<dict>
		<key>com.apple.iokit.IOPCIFamily</key>
		<string>2.9</string>

		<key>com.apple.kpi.iokit</key>
		<string>8.0</string>

		<key>com.apple.kpi.libkern</key>
		<string>8.0</string>
	</dict>

	<!-- Load at Safe Boot so the fix is applied even in recovery. -->
	<key>OSBundleRequired</key>
	<string>Safe Boot</string>

	<!-- Minimum macOS version: Sonoma (14.0), targets Sequoia (15.x). -->
	<key>LSMinimumSystemVersion</key>
	<string>14.0</string>

</dict>
</plist>
